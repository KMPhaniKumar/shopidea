# ─────────────────────────────────────────────────────────────
# ReelMart — Microservices Environment Variables
# Copy this to reelmart/services/.env and fill in your values
# ─────────────────────────────────────────────────────────────

# Supabase (required by all services)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Inter-service auth key (make up any random string)
INTERNAL_API_KEY=change-me-random-32-char-secret

# Razorpay (payment-service + whatsapp-service)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXX

# Shiprocket (delivery-service)
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your_shiprocket_password

# Gupshup WhatsApp (notification-service + whatsapp-service)
GUPSHUP_API_KEY=your_gupshup_api_key
GUPSHUP_SENDER_NUMBER=+91XXXXXXXXXX
GUPSHUP_APP_NAME=ReelMart

# Firebase FCM (notification-service)
# Paste the full JSON as a single line (escape quotes)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# CORS — set to your EC2 public IP after deployment
# Example: http://13.235.100.200
ALLOWED_ORIGINS=http://localhost:3000
